# CI-oriented Docker Compose runtime configuration.
# This file documents stable defaults for automated validation runs.

# Expose the FastAPI service on the default CI host port.
APP_PORT=8000

# Keep resource limits conservative and deterministic for CI runners.
APP_CPUS=1.00
APP_MEMORY_LIMIT=512m

# Example model name used during CI deployment smoke test
# Required for settings validation (fail-fast behavior)
MODEL_NAME=fraud-detection-model
